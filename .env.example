# Copy to .env and fill in. The site builds without these (falls back to a
# cached snapshot), but a token unlocks live, rate-limit-free GitHub data.

# GitHub username to feature on the site.
PUBLIC_GITHUB_USERNAME=nicholasjvr

# Which repos appear is curated in src/data/featured-repos.ts — NOT here.
#
# Token guidance:
#   - All featured repos PUBLIC  -> token optional (only raises rate limits).
#   - Any featured repo PRIVATE  -> use a FINE-GRAINED PAT scoped to ONLY those
#     repositories, with read-only "Metadata" permission. Never a classic
#     `repo`-scope token (that exposes every private repo you own).
# Used at build time only; never shipped to the browser. Keep it as a CI/Vercel
# secret, never commit it.
GITHUB_TOKEN=
