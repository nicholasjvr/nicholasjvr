---
import { TERMINAL_ART, TERMINAL_PROMPT } from '../data/terminal-art';

const initial = TERMINAL_ART[0];
---

<div
  class="ascii-terminal reveal mt-12 overflow-hidden rounded-xl border border-border bg-surface-2/80 shadow-card"
  data-ascii-terminal
>
  <div class="flex items-center justify-between gap-3 border-b border-border bg-surface px-4 py-3">
    <div class="flex items-center gap-2" aria-hidden="true">
      <span class="h-3 w-3 rounded-full bg-danger/80"></span>
      <span class="h-3 w-3 rounded-full bg-accent/40"></span>
      <span class="h-3 w-3 rounded-full bg-success/70"></span>
    </div>
    <p class="truncate font-mono text-xs text-muted">~/ascii/random_pager</p>
    <p class="font-mono text-[10px] uppercase tracking-widest text-accent/70" data-terminal-status>
      live
    </p>
  </div>

  <div class="relative p-4 md:p-6">
    <div class="scanline-overlay pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true"></div>

    <p class="font-mono text-sm text-muted">
      <span class="text-accent">{TERMINAL_PROMPT}</span>
      <span data-terminal-command> cat {initial.file}</span><span class="terminal-cursor" aria-hidden="true">▋</span>
    </p>

    <pre
      class="terminal-art mt-4 min-h-[11rem] overflow-x-auto font-mono text-[0.62rem] leading-tight text-accent sm:text-xs md:text-sm"
      data-terminal-art
      aria-live="polite"
    >{initial.art}</pre>

    <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.2em] text-muted/70" data-terminal-meta>
      paging ascii // frame 1/{TERMINAL_ART.length}
    </p>
  </div>
</div>

<script define:vars={{ frames: TERMINAL_ART, prompt: TERMINAL_PROMPT }}>
  const root = document.querySelector('[data-ascii-terminal]');
  if (!root) return;

  const artEl = root.querySelector('[data-terminal-art]');
  const commandEl = root.querySelector('[data-terminal-command]');
  const metaEl = root.querySelector('[data-terminal-meta]');
  const statusEl = root.querySelector('[data-terminal-status]');

  if (!artEl || !commandEl || !metaEl) return;

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const dwellMs = reducedMotion ? 12000 : 5500;
  const flickerMs = reducedMotion ? 0 : 180;

  let index = 0;
  let timer = null;
  let visible = false;

  function pickNextIndex() {
    if (frames.length <= 1) return 0;
    let next = index;
    while (next === index) {
      next = Math.floor(Math.random() * frames.length);
    }
    return next;
  }

  function setFrame(nextIndex) {
    const frame = frames[nextIndex];
    index = nextIndex;
    commandEl.textContent = ` cat ${frame.file}`;
    artEl.textContent = frame.art;
    metaEl.textContent = `paging ascii // frame ${nextIndex + 1}/${frames.length} // ${frame.file}`;
    if (statusEl) statusEl.textContent = 'live';
  }

  function flickerTo(nextIndex) {
    if (flickerMs === 0) {
      setFrame(nextIndex);
      return;
    }

    root.classList.add('is-switching');
    if (statusEl) statusEl.textContent = 'load';

    window.setTimeout(() => {
      setFrame(nextIndex);
      root.classList.remove('is-switching');
    }, flickerMs);
  }

  function scheduleNext() {
    window.clearTimeout(timer);
    if (!visible) return;
    timer = window.setTimeout(() => {
      flickerTo(pickNextIndex());
      scheduleNext();
    }, dwellMs);
  }

  function start() {
    visible = true;
    scheduleNext();
  }

  function stop() {
    visible = false;
    window.clearTimeout(timer);
    timer = null;
  }

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) start();
          else stop();
        }
      },
      { rootMargin: '0px 0px -10% 0px' }
    );
    io.observe(root);
  } else {
    start();
  }
</script>

<style>
  .ascii-terminal {
    box-shadow:
      0 0 0 1px rgb(var(--c-border) / 0.8),
      0 12px 40px -16px rgb(0 0 0 / 0.55),
      0 0 48px -20px rgb(var(--c-accent) / 0.12);
  }

  .terminal-art {
    text-shadow: 0 0 12px rgb(var(--c-accent) / 0.25);
    white-space: pre;
  }

  .terminal-cursor {
    color: rgb(var(--c-accent));
    animation: terminal-blink 1s step-end infinite;
  }

  .scanline-overlay {
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgb(0 0 0 / 0.35) 2px,
      rgb(0 0 0 / 0.35) 4px
    );
  }

  .ascii-terminal.is-switching .terminal-art {
    opacity: 0.15;
    filter: blur(1px);
    transition: opacity 0.12s ease, filter 0.12s ease;
  }

  .ascii-terminal.is-switching [data-terminal-command] {
    opacity: 0.35;
  }

  @keyframes terminal-blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-cursor {
      animation: none;
    }
  }
</style>
