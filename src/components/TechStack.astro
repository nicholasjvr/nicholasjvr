---
import { TECH_STACK } from '../data/copy';
---

<section id="stack" class="section">
  <p class="eyebrow reveal">{TECH_STACK.eyebrow}</p>
  <h2 class="reveal mt-4 text-3xl font-semibold tracking-tight text-ink md:text-4xl">
    {TECH_STACK.title}
  </h2>

  <div class="reveal mt-12 grid gap-12 md:grid-cols-2">
    <div>
      <h3 class="font-mono text-sm font-semibold uppercase tracking-wide text-muted">
        {TECH_STACK.core.label}
      </h3>
      <div class="mt-5 border-l-2 border-accent pl-4">
        <p class="text-2xl font-semibold tracking-tight text-ink">
          {TECH_STACK.core.primary}
          <span class="ml-2 align-middle text-xs font-medium uppercase tracking-wide text-accent">
            primary
          </span>
        </p>
      </div>
      <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 font-mono text-sm text-muted">
        {TECH_STACK.core.items.map((item) => <span>{item}</span>)}
      </div>
    </div>

    <div>
      <h3 class="font-mono text-sm font-semibold uppercase tracking-wide text-muted">
        {TECH_STACK.additional.label}
      </h3>
      <div class="mt-5 flex flex-wrap gap-x-5 gap-y-2 font-mono text-sm text-muted">
        {TECH_STACK.additional.items.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </div>
</section>
