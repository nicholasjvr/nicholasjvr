---
import { SITE } from '../data/site';

const username = import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr';
const year = new Date().getFullYear();
---

<footer class="site-footer mt-auto">
  <div class="mx-auto max-w-content px-6 py-14">
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-md">
        <p class="text-lg font-semibold text-ink">Nicholas van Rensburg</p>
        <p class="mt-2 text-sm leading-relaxed text-muted">{SITE.tagline}</p>
      </div>

      <div class="flex flex-wrap gap-6 text-sm font-medium">
        <a href={`mailto:${SITE.email}`} class="text-muted transition hover:text-accent">
          {SITE.email}
        </a>
        <a
          href={`https://github.com/${username}`}
          target="_blank"
          rel="noopener"
          class="text-muted transition hover:text-accent"
        >
          GitHub
        </a>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-center justify-between gap-3 border-t border-border pt-6 text-xs text-muted sm:flex-row">
      <p>© {year} Nicholas van Rensburg</p>
      <p>Built with Astro + Tailwind</p>
    </div>
  </div>
</footer>
