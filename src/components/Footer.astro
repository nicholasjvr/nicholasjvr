---
import { SITE } from '../data/site';

const username = import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr';
const year = new Date().getFullYear();

// A small "elsewhere on the web" block: the tasteful descendant of the webring.
const elsewhere = [
  { label: 'github', href: `https://github.com/${username}` },
  { label: 'email', href: `mailto:${SITE.email}` },
];
---

<footer class="site-footer mt-auto">
  <div class="mx-auto max-w-content px-5 py-12">
    <div class="term-window">
      <div class="term-titlebar">
        <span class="term-dot" style="background:#f85149" aria-hidden="true"></span>
        <span class="term-dot" style="background:#d2a24c" aria-hidden="true"></span>
        <span class="term-dot" style="background:#3fb950" aria-hidden="true"></span>
        <span class="ml-2 text-xs text-muted">~/footer</span>
      </div>

      <div class="space-y-4 p-5 text-sm md:p-6">
        <p class="prompt text-ink">echo "thanks for scrolling"</p>
        <p class="max-w-md text-muted">{SITE.tagline}</p>

        <p class="prompt mt-5 text-ink">ls ./elsewhere</p>
        <div class="flex flex-wrap gap-2">
          {
            elsewhere.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener' : undefined}
                class="tag tag-accent transition hover:bg-accent/10"
              >
                ./{link.label}
              </a>
            ))
          }
        </div>

        <div class="mt-6 border-t border-border pt-4 text-xs text-muted">
          <p># {year} {SITE.name} · hand-built with Astro + Tailwind</p>
          <p class="mt-1"># no analytics, no cookies, no funnel. just a homepage.</p>
        </div>
      </div>
    </div>
  </div>
</footer>
