---
import { HERO } from '../data/copy';

const githubUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr'}`;
const secondaryHref = HERO.ctaSecondary.href === 'github' ? githubUrl : HERO.ctaSecondary.href;
const secondaryExternal = HERO.ctaSecondary.href === 'github';

// Build-time stamp. Real data, printed like terminal output.
const builtAt = new Date().toISOString().slice(0, 16).replace('T', ' ');
---

<section class="section pt-20 md:pt-28">
  <!-- Terminal window: the hero is a shell session, not a marketing headline. -->
  <div class="term-window reveal max-w-3xl">
    <div class="term-titlebar">
      <span class="term-dot" style="background:#f85149" aria-hidden="true"></span>
      <span class="term-dot" style="background:#d2a24c" aria-hidden="true"></span>
      <span class="term-dot" style="background:#3fb950" aria-hidden="true"></span>
      <span class="ml-2 text-xs text-muted">~/nicholasjvr - zsh - 80×24</span>
    </div>

    <div class="space-y-4 p-5 text-sm leading-relaxed md:p-7 md:text-base">
      <p class="prompt text-ink">whoami</p>
      <h1 class="text-2xl font-bold leading-tight tracking-tight text-ink md:text-4xl">
        {HERO.name}
      </h1>
      <p class="text-accent">{HERO.role}</p>

      <p class="prompt mt-6 text-ink">cat ./about.txt</p>
      <p class="max-w-2xl text-muted">{HERO.line}</p>
      <p class="max-w-2xl text-ink">
        {HERO.signatureBefore}{' '}
        <span class="text-accent-warm">{HERO.signatureAccent}</span>
      </p>

      <p class="prompt mt-6 text-ink">./run<span class="cursor" aria-hidden="true"></span></p>

      <div class="flex flex-wrap items-center gap-2.5 pt-1">
        <a href={HERO.ctaPrimary.href} class="btn-primary">[ {HERO.ctaPrimary.label.toLowerCase().replace(/\s+/g, '_')} ]</a>
        <a
          href={secondaryHref}
          class="btn-ghost"
          {...(secondaryExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          [ {HERO.ctaSecondary.label.toLowerCase()} ]
        </a>
      </div>

      <p class="pt-3 text-xs text-muted">
        # last build: {builtAt} UTC · node env: hobby · warranty: none
      </p>
    </div>
  </div>
</section>
