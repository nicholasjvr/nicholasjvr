---
import { HERO } from '../data/copy';

const githubUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr'}`;
const secondaryHref = HERO.ctaSecondary.href === 'github' ? githubUrl : HERO.ctaSecondary.href;
const secondaryExternal = HERO.ctaSecondary.href === 'github';
---

<section class="section pt-24 md:pt-36">
  <p class="eyebrow reveal">{HERO.role}</p>
  <h1
    class="reveal mt-5 max-w-4xl text-5xl font-semibold leading-[1.05] tracking-tight text-ink md:text-7xl"
  >
    {HERO.name}
  </h1>
  <p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
    {HERO.line}
  </p>
  <p class="reveal mt-3 max-w-2xl text-lg leading-relaxed text-ink md:text-xl">
    {HERO.signatureBefore}{' '}
    <span class="text-accent-warm">{HERO.signatureAccent}</span>
  </p>

  <div class="reveal mt-9 flex flex-wrap items-center gap-3">
    <a href={HERO.ctaPrimary.href} class="btn-primary">{HERO.ctaPrimary.label}</a>
    <a
      href={secondaryHref}
      class="btn-ghost"
      {...(secondaryExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
    >
      {HERO.ctaSecondary.label}
    </a>
  </div>
</section>
