---
interface Props {
  label: string;
  value: string;
}
const { label, value } = Astro.props;
---

<div class="card-surface rounded-xl px-4 py-3 text-center">
  <div class="font-mono text-xl font-semibold text-ink md:text-2xl">{value}</div>
  <div class="mt-1 text-xs font-medium uppercase tracking-wide text-muted">{label}</div>
</div>
