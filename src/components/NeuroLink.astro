---
import { HOW_I_WORK, NEURO_LINK } from '../data/copy';

// Radial neural-graph layout. The training core sits at the center; each agent
// is a node on an ellipse around it, wired in with a glowing "signal" edge.
const VIEW_W = 880;
const VIEW_H = 480;
const CX = VIEW_W / 2;
const CY = VIEW_H / 2;
const RX = 330;
const RY = 180;

const agents = HOW_I_WORK.agents;
const count = agents.length;

const nodes = agents.map((agent, i) => {
  // Start at the top and distribute evenly around the ellipse.
  const theta = -Math.PI / 2 + (i / count) * Math.PI * 2;
  const x = CX + RX * Math.cos(theta);
  const y = CY + RY * Math.sin(theta);
  const cos = Math.cos(theta);

  // Anchor labels outward so they never overlap the core.
  let anchor: 'start' | 'middle' | 'end' = 'middle';
  if (cos > 0.3) anchor = 'start';
  else if (cos < -0.3) anchor = 'end';

  const labelOffset = anchor === 'start' ? 16 : anchor === 'end' ? -16 : 0;
  const labelDy = Math.sin(theta) >= 0 ? 22 : -14;

  return {
    ...agent,
    x: Math.round(x),
    y: Math.round(y),
    anchor,
    labelX: Math.round(x + labelOffset),
    labelY: Math.round(y + labelDy),
    // Delta from node toward the core, for the traveling signal particle.
    dx: Math.round(CX - x),
    dy: Math.round(CY - y),
    // Stagger edge animations so signals don't all pulse in unison.
    delay: (i * 0.35).toFixed(2),
    warm: i % 2 === 0,
  };
});
---

<figure class="neurolink m-0" aria-label="Neural graph of AI agents wired into a training core">
  <svg
    viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
    width="100%"
    role="img"
    preserveAspectRatio="xMidYMid meet"
    class="block w-full"
  >
    <defs>
      <radialGradient id="neuro-core" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFE3F2" />
        <stop offset="35%" stop-color="#FF0087" />
        <stop offset="100%" stop-color="#6B00FF" />
      </radialGradient>
      <radialGradient id="neuro-node" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#CFFCFF" />
        <stop offset="60%" stop-color="#00F7FF" />
        <stop offset="100%" stop-color="#0066FF" />
      </radialGradient>
      <radialGradient id="neuro-node-warm" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFD9EC" />
        <stop offset="60%" stop-color="#FF00AA" />
        <stop offset="100%" stop-color="#B026FF" />
      </radialGradient>
      <filter id="neuro-glow" x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="5" result="b" />
        <feMerge>
          <feMergeNode in="b" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    {/* faint backdrop ellipse / orbit ring */}
    <ellipse
      cx={CX}
      cy={CY}
      rx={RX}
      ry={RY}
      fill="none"
      stroke="rgba(0,247,255,0.10)"
      stroke-width="1"
      stroke-dasharray="3 7"
    />

    {/* edges: signal flowing inward toward the core */}
    {
      nodes.map((n) => (
        <line
          x1={n.x}
          y1={n.y}
          x2={CX}
          y2={CY}
          class:list={['neuro-edge', { 'neuro-edge-warm': n.warm }]}
          style={`--delay:${n.delay}s`}
        />
      ))
    }

    {/* traveling signal particles: dots that ride each edge into the core */}
    {
      nodes.map((n) => (
        <circle
          cx={n.x}
          cy={n.y}
          r="3.2"
          class:list={['neuro-particle', { 'neuro-particle-warm': n.warm }]}
          style={`--dx:${n.dx}px; --dy:${n.dy}px; --delay:${n.delay}s`}
        />
      ))
    }

    {/* agent nodes */}
    {
      nodes.map((n) => (
        <g class="neuro-node" style={`--delay:${n.delay}s`}>
          <circle cx={n.x} cy={n.y} r="16" class="neuro-node-halo" />
          <circle
            cx={n.x}
            cy={n.y}
            r="7"
            fill={n.warm ? 'url(#neuro-node-warm)' : 'url(#neuro-node)'}
            filter="url(#neuro-glow)"
          />
          <text
            x={n.labelX}
            y={n.labelY}
            text-anchor={n.anchor}
            class="neuro-label"
          >
            {n.short}
          </text>
        </g>
      ))
    }

    {/* central training core */}
    <g class="neuro-core-group">
      <circle cx={CX} cy={CY} r="48" class="neuro-core-halo" />
      <circle cx={CX} cy={CY} r="30" fill="url(#neuro-core)" filter="url(#neuro-glow)" />
      <text x={CX} y={CY + 4} text-anchor="middle" class="neuro-core-mark">ME</text>
      <text x={CX} y={CY + 70} text-anchor="middle" class="neuro-core-label">
        {NEURO_LINK.coreLabel}
      </text>
      <text x={CX} y={CY + 86} text-anchor="middle" class="neuro-core-sub">
        {NEURO_LINK.coreSubLabel}
      </text>
    </g>
  </svg>
</figure>

<style>
  .neurolink {
    width: 100%;
  }

  .neuro-edge {
    stroke: rgba(0, 247, 255, 0.55);
    stroke-width: 1.4;
    stroke-dasharray: 5 10;
    animation: neuro-flow 2.4s linear infinite;
    animation-delay: var(--delay, 0s);
  }

  .neuro-edge-warm {
    stroke: rgba(255, 0, 135, 0.55);
  }

  /* Negative offset travel = dashes move from node toward the core. */
  @keyframes neuro-flow {
    to {
      stroke-dashoffset: -45;
    }
  }

  .neuro-particle {
    fill: #cffcff;
    filter: drop-shadow(0 0 4px #00f7ff);
    animation: neuro-travel 2.4s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
  }

  .neuro-particle-warm {
    fill: #ffd9ec;
    filter: drop-shadow(0 0 4px #ff0087);
  }

  /* Ride from the agent node into the training core, then fade and restart. */
  @keyframes neuro-travel {
    0% {
      transform: translate(0, 0);
      opacity: 0;
    }
    12% {
      opacity: 1;
    }
    82% {
      opacity: 1;
    }
    100% {
      transform: translate(var(--dx, 0), var(--dy, 0));
      opacity: 0;
    }
  }

  .neuro-node-halo {
    fill: rgba(0, 247, 255, 0.12);
    animation: neuro-pulse 3s ease-in-out infinite;
    animation-delay: var(--delay, 0s);
    transform-box: fill-box;
    transform-origin: center;
  }

  .neuro-node:hover .neuro-node-halo {
    fill: rgba(0, 247, 255, 0.28);
  }

  @keyframes neuro-pulse {
    0%,
    100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.25);
    }
  }

  .neuro-label {
    fill: rgb(var(--c-muted));
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    letter-spacing: 0.04em;
    transition: fill 0.2s ease;
  }

  .neuro-node:hover .neuro-label {
    fill: rgb(var(--c-ink));
  }

  .neuro-core-halo {
    fill: rgba(255, 0, 135, 0.14);
    animation: neuro-core-pulse 2.6s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  @keyframes neuro-core-pulse {
    0%,
    100% {
      opacity: 0.5;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.18);
    }
  }

  .neuro-core-mark {
    fill: #fff;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.1em;
  }

  .neuro-core-label {
    fill: rgb(var(--c-ink));
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
  }

  .neuro-core-sub {
    fill: rgb(var(--c-muted));
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
  }

  @media (prefers-reduced-motion: reduce) {
    .neuro-edge,
    .neuro-node-halo,
    .neuro-core-halo {
      animation: none;
    }

    .neuro-particle {
      display: none;
    }
  }
</style>
