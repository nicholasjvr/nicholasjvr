---
import { getGitHubData } from '../lib/github';

// Build-time fetch with cache fallback. Keeps the site and the GitHub profile in
// lockstep on every deploy.
const gh = await getGitHubData();

function timeAgo(iso: string): string {
  const days = Math.round((Date.now() - new Date(iso).getTime()) / 86_400_000);
  if (days <= 0) return 'today';
  if (days === 1) return '1 day ago';
  if (days < 30) return `${days} days ago`;
  const months = Math.round(days / 30);
  return months === 1 ? '1 month ago' : `${months} months ago`;
}
---

<section id="github" class="section">
  <p class="eyebrow reveal">In sync with my profile</p>
  <h2 class="reveal mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
    Live from GitHub
  </h2>

  <div class="reveal mt-10 grid gap-6 lg:grid-cols-3">
    <!-- Profile + languages -->
    <div class="rounded-2xl border border-border bg-surface p-6 shadow-card">
      <div class="flex items-center gap-4">
        <img
          src={gh.profile.avatarUrl}
          alt={`${gh.profile.username} avatar`}
          width="56"
          height="56"
          class="h-14 w-14 rounded-full border border-border"
        />
        <div>
          <a href={gh.profile.profileUrl} target="_blank" rel="noopener" class="font-bold text-ink hover:text-accent">
            @{gh.profile.username}
          </a>
          <p class="text-sm text-muted">
            {gh.profile.publicRepos} repos · {gh.profile.followers} followers
          </p>
        </div>
      </div>
      {gh.profile.bio && <p class="mt-4 text-sm leading-relaxed text-muted">{gh.profile.bio}</p>}

      {
        gh.topLanguages.length > 0 && (
          <div class="mt-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-muted">Top languages</p>
            <div class="mt-2 flex flex-wrap gap-1.5">
              {gh.topLanguages.map((l) => (
                <span class="rounded-full border border-border bg-surface-2 px-2.5 py-1 text-xs font-medium text-ink">
                  {l.name}
                </span>
              ))}
            </div>
          </div>
        )
      }
    </div>

    <!-- Repos -->
    <div class="lg:col-span-2 grid gap-4 sm:grid-cols-2">
      {
        gh.repos.map((repo) => (
          <a
            href={repo.url}
            target="_blank"
            rel="noopener"
            class="group flex flex-col rounded-2xl border border-border bg-surface p-5 shadow-card transition-all hover:-translate-y-0.5 hover:shadow-card-hover"
          >
            <div class="flex items-center justify-between gap-2">
              <span class="truncate font-semibold text-ink group-hover:text-accent">{repo.name}</span>
              <span class="shrink-0 text-xs text-muted">★ {repo.stars}</span>
            </div>
            {repo.description && (
              <p class="mt-2 line-clamp-2 text-sm text-muted">{repo.description}</p>
            )}
            <div class="mt-auto flex items-center gap-3 pt-4 text-xs text-muted">
              {repo.language && (
                <span class="inline-flex items-center gap-1.5">
                  <span class="h-2 w-2 rounded-full bg-accent" />
                  {repo.language}
                </span>
              )}
              <span>Updated {timeAgo(repo.pushedAt)}</span>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <p class="reveal mt-4 text-xs text-muted">
    {gh.source === 'live' ? 'Fetched live at build' : 'Showing cached snapshot'} · {gh.fetchedAt.slice(0, 10)}
  </p>
</section>
