---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, slug } = project;

// Status rendered as a bracketed build state: [ live ] / [ wip ] / [ archived ].
const statusStyles: Record<string, string> = {
  live: 'tag-accent',
  wip: 'tag-warm',
  archived: '',
};
const statusLabel: Record<string, string> = {
  live: 'live',
  wip: 'wip',
  archived: 'archived',
};
---

<a
  href={withBase(`/projects/${slug}`)}
  class="project-card group relative flex flex-col overflow-hidden"
  data-skills={data.skills.join(',')}
>
  <!-- File-listing style header: a project reads like an entry in `ls -la`. -->
  <div class="flex items-center gap-2 border-b border-border px-4 py-2.5 text-xs text-muted">
    <span class="text-accent">drwxr-xr-x</span>
    <span class="truncate">~/projects/{slug}</span>
    <span class:list={['tag ml-auto shrink-0', statusStyles[data.status]]}>
      {statusLabel[data.status]}
    </span>
  </div>

  <div class="aspect-[16/9] overflow-hidden border-b border-border bg-surface-2">
    <img
      src={withBase(data.cover)}
      alt={`${data.title} preview`}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>

  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-base font-bold text-ink">{data.title}</h3>
    <p class="mt-2 text-sm leading-relaxed text-muted">{data.tagline}</p>

    <span class="mt-5 inline-flex items-center text-sm font-medium text-accent">
      $ open
      <span class="ml-2 transition-transform group-hover:translate-x-1">&gt;</span>
    </span>
  </div>
</a>
