---
import type { CollectionEntry } from 'astro:content';
import { withBase } from '../lib/paths';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { data, slug } = project;

const statusStyles: Record<string, string> = {
  live: 'text-success',
  wip: 'text-accent',
  archived: 'text-muted',
};
const statusLabel: Record<string, string> = {
  live: 'Live',
  wip: 'In progress',
  archived: 'Archived',
};
---

<a
  href={withBase(`/projects/${slug}`)}
  class="project-card group flex flex-col overflow-hidden"
  data-skills={data.skills.join(',')}
>
  <div class="aspect-[16/9] overflow-hidden border-b border-border bg-surface-2">
    <img
      src={withBase(data.cover)}
      alt={`${data.title} preview`}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center justify-between gap-3">
      <h3 class="text-lg font-semibold text-ink">{data.title}</h3>
      <span class:list={['shrink-0 text-xs font-semibold uppercase tracking-wide', statusStyles[data.status]]}>
        {statusLabel[data.status]}
      </span>
    </div>
    <p class="mt-3 text-sm leading-relaxed text-muted">{data.tagline}</p>

    <span class="mt-6 inline-flex items-center text-sm font-semibold text-accent">
      View project
      <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
    </span>
  </div>
</a>
