---
import type { CollectionEntry } from 'astro:content';
import SkillBadge from './SkillBadge.astro';
import { withBase } from '../lib/paths';
import type { AccentTheme } from '../data/project-themes';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { data, slug } = project;
const theme = (data.accentTheme ?? 'default') as AccentTheme;

const statusStyles: Record<string, string> = {
  live: 'border-success/30 bg-success/10 text-success',
  wip: 'border-accent/30 bg-accent-soft/50 text-accent',
  archived: 'border-border bg-surface-2 text-muted',
};
const statusLabel: Record<string, string> = {
  live: 'Live',
  wip: 'In progress',
  archived: 'Archived',
};
---

<a
  href={withBase(`/projects/${slug}`)}
  class="project-card group flex flex-col overflow-hidden"
  data-skills={data.skills.join(',')}
  data-accent-theme={theme !== 'default' ? theme : undefined}
>
  <div class="aspect-[16/9] overflow-hidden border-b border-border/80 bg-surface-2 ring-1 ring-inset ring-accent/5">
    <img
      src={withBase(data.cover)}
      alt={`${data.title} preview`}
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>

  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-center justify-between gap-3">
      <h3 class="font-bold text-ink">{data.title}</h3>
      <span
        class:list={['shrink-0 rounded-full border px-2 py-0.5 text-[11px] font-semibold', statusStyles[data.status]]}
      >
        {statusLabel[data.status]}
      </span>
    </div>
    <p class="mt-2 text-sm leading-relaxed text-muted">{data.tagline}</p>

    <div class="mt-4 flex flex-wrap gap-1.5">
      {data.skills.slice(0, 5).map((s) => <SkillBadge skillKey={s} />)}
      {
        data.skills.length > 5 && (
          <span class="inline-flex items-center rounded-full border border-border bg-surface px-2.5 py-1 text-xs font-medium text-muted">
            +{data.skills.length - 5}
          </span>
        )
      }
    </div>

    <span class="mt-5 inline-flex items-center text-sm font-semibold text-gradient">
      Read case study
      <span class="ml-1 transition-transform group-hover:translate-x-1">→</span>
    </span>
  </div>
</a>
