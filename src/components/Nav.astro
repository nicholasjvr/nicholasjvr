---
import { SITE } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: `${import.meta.env.BASE_URL}#projects`, label: 'Projects' },
  { href: `${import.meta.env.BASE_URL}#stack`, label: 'Stack' },
];
const githubUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr'}`;
---

<header class="site-chrome sticky top-0 z-40 backdrop-blur-md">
  <nav class="mx-auto flex max-w-content items-center justify-between gap-4 px-6 py-4">
    <a href={import.meta.env.BASE_URL} class="font-semibold tracking-tight text-ink" aria-label={`${SITE.name} home`}>
      <span class="text-base sm:text-lg">Nicholas van Rensburg</span>
      <span class="mt-0.5 block text-[10px] font-medium uppercase tracking-[0.18em] text-muted">
        {SITE.role}
      </span>
    </a>

    <div class="flex items-center gap-1.5 sm:gap-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="hidden rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:text-ink sm:inline-block"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener"
        class="rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:text-ink"
      >
        GitHub
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>
