---
import { SITE } from '../data/site';
import ThemeToggle from './ThemeToggle.astro';
import { withBase } from '../lib/paths';

const links = [
  { href: `${import.meta.env.BASE_URL}#projects`, label: 'Projects' },
  { href: `${import.meta.env.BASE_URL}#skills`, label: 'Skills' },
  { href: `${import.meta.env.BASE_URL}#github`, label: 'GitHub' },
];
const githubUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr'}`;
---

<header class="site-chrome sticky top-0 z-40 backdrop-blur-md">
  <nav class="mx-auto flex max-w-content items-center justify-between gap-4 px-6 py-3.5">
    <a href={import.meta.env.BASE_URL} class="group font-bold tracking-tight text-ink" aria-label={`${SITE.name} home`}>
      <span class="text-base sm:text-lg">
        nicholas<span class="text-gradient">jvr</span>
      </span>
      <span class="mt-0.5 block text-[10px] font-medium uppercase tracking-[0.2em] text-muted group-hover:text-accent">
        Software &amp; ML
      </span>
    </a>

    <div class="flex items-center gap-1.5 sm:gap-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="hidden rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:bg-surface-2/80 hover:text-ink sm:inline-block"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={withBase('/projects')}
        class="hidden rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:bg-surface-2/80 hover:text-ink md:inline-block"
      >
        All work
      </a>
      <ThemeToggle />
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-gradient-to-r from-accent to-accent-2 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:brightness-105"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
