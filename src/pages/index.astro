---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhatIDo from '../components/WhatIDo.astro';
import HowIWork from '../components/HowIWork.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TechStack from '../components/TechStack.astro';
import { PROJECTS_SECTION, CONTACT_CTA } from '../data/copy';
import { withBase } from '../lib/paths';

const featured = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const githubUrl = `https://github.com/${import.meta.env.PUBLIC_GITHUB_USERNAME || 'nicholasjvr'}`;
---

<BaseLayout>
  <Hero />

  <section id="projects" class="section">
    <div class="flex items-end justify-between">
      <div>
        <p class="eyebrow reveal">{PROJECTS_SECTION.eyebrow}</p>
        <h2 class="reveal mt-4 text-3xl font-semibold tracking-tight text-ink md:text-4xl">
          {PROJECTS_SECTION.title}
        </h2>
      </div>
      <a href={withBase('/projects')} class="reveal hidden text-sm font-semibold text-accent hover:underline sm:inline">
        All projects →
      </a>
    </div>

    <div class="project-cards-3d reveal mt-12 grid gap-8 md:grid-cols-2">
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>

    <div class="mt-8 sm:hidden">
      <a href={withBase('/projects')} class="text-sm font-semibold text-accent hover:underline">All projects →</a>
    </div>
  </section>

  <WhatIDo />
  <HowIWork />
  <TechStack />

  <section id="contact" class="section">
    <div class="reveal card-surface rounded-2xl p-10 text-center md:p-16">
      <h2 class="text-2xl font-semibold tracking-tight text-ink md:text-4xl">{CONTACT_CTA.title}</h2>
      <p class="mx-auto mt-4 max-w-xl text-muted">{CONTACT_CTA.body}</p>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary mt-8 inline-block"
      >
        {CONTACT_CTA.cta.label}
      </a>
    </div>
  </section>
</BaseLayout>
