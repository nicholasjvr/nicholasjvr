---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getSkill } from '../../data/skills';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// Build the filter chip set from skills actually present across projects.
const skillKeys = [...new Set(projects.flatMap((p) => p.data.skills))];
const filters = skillKeys
  .map((k) => getSkill(k))
  .sort((a, b) => a.label.localeCompare(b.label));
---

<BaseLayout title="Projects | Nicholas" description="All project case studies.">
  <section class="section">
    <p class="eyebrow reveal">Case studies</p>
    <h1 class="reveal mt-3 text-4xl font-extrabold tracking-tight text-ink md:text-5xl">
      Projects
    </h1>
    <p class="reveal mt-3 max-w-2xl text-muted">
      Each project is written up as a case study: the objective, the approach,
      and the skills used to get there. Filter by skill below.
    </p>

    <!-- Skill filter chips (client-side, no framework) -->
    <div id="filters" class="reveal mt-8 flex flex-wrap gap-2">
      <button
        type="button"
        data-filter="all"
        class="filter-chip is-active rounded-full border border-accent/40 bg-gradient-to-r from-accent-soft to-accent-2/10 px-3 py-1.5 text-sm font-medium text-accent"
      >
        All
      </button>
      {
        filters.map((f) => (
          <button
            type="button"
            data-filter={f.key}
            class="filter-chip rounded-full border border-border bg-surface px-3 py-1.5 text-sm font-medium text-muted transition-colors hover:text-ink"
          >
            {f.label}
          </button>
        ))
      }
    </div>

    <div id="project-grid" class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => <ProjectCard project={project} />)}
    </div>

    <p id="empty" class="mt-10 hidden text-center text-muted">No projects match that skill yet.</p>
  </section>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
  const cards = document.querySelectorAll<HTMLAnchorElement>('#project-grid > a');
  const empty = document.getElementById('empty');

  const setActive = (active: HTMLButtonElement) => {
    chips.forEach((c) => {
      const on = c === active;
      c.classList.toggle('is-active', on);
      c.classList.toggle('border-accent', on);
      c.classList.toggle('bg-accent-soft', on);
      c.classList.toggle('text-accent', on);
      c.classList.toggle('border-border', !on);
      c.classList.toggle('bg-surface', !on);
      c.classList.toggle('text-muted', !on);
    });
  };

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      setActive(chip);
      const filter = chip.dataset.filter;
      let visible = 0;
      cards.forEach((card) => {
        const skills = (card.dataset.skills || '').split(',');
        const show = filter === 'all' || skills.includes(filter!);
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      empty?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
